{ Initialiser le syst猫me de blocs }
Procedure InitBlockSystem;
Var
 I: Integer;
Begin
 BlockDefCount := 0;
 BlockRefCount := 0;
 XRefCount := 0;
 BlockEntityCount := 0;

 { Initialiser toutes les d茅finitions de blocs }
 For I := 0 to MAX_BLOCKS - 1 do Begin
  BlockDefs[I].Name := '';
  BlockDefs[I].Description := '';
  BlockDefs[I].BaseX := 0;
  BlockDefs[I].BaseY := 0;
  BlockDefs[I].EntityCount := 0;
  BlockDefs[I].FirstEntityIdx := -1;
  BlockDefs[I].IsXRef := False;
  BlockDefs[I].XRefPath := '';
  BlockDefs[I].IsDefined := False;
 End;

 { Initialiser toutes les r茅f茅rences de blocs }
