{ Proc茅dures pour obtenir le delta de la molette via clavier - TODO 7 }
Procedure ProcessMouseWheelFromKeyboard(Key: Char);
Begin
 Case Key of
  '+', '=': HandleMouseWheel(1);  { Zoom avant }
  '-', '_': HandleMouseWheel(-1); { Zoom arri猫re }
 End;
End;

