  XRefs[I].FilePath := '';
  XRefs[I].InsertX := 0;
  XRefs[I].InsertY := 0;
  XRefs[I].ScaleX := 1.0;
  XRefs[I].ScaleY := 1.0;
  XRefs[I].Rotation := 0;
  XRefs[I].Status := XREF_UNLOADED;
  XRefs[I].BlockIndex := -1;
  XRefs[I].LayerPrefix := '';
  XRefs[I].Overlay := False;
  XRefs[I].Selected := False;
  XRefs[I].Visible := True;
